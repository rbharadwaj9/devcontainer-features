{
  "name": "rbharadwaj9 stow based dotfiles installer",
  "id": "dotfiles",
  "version": "0.0.7",
  "description": "Clones and installs dotfiles using stow",
  "dependsOn": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/duduribeiro/devcontainer-features/tmux:1": {},
    "ghcr.io/rbharadwaj9/devcontainer-features/neovim:0": {}
  },
  "containerEnv": {
    "RBHARADWAJ_DEVC": "1"
  },
  "options": {
    "repo": {
      "type": "string",
      "default": "https://github.com/rbharadwaj9/dotfiles.git",
      "description": "Dotfiles repository"
    },
    "targetUser": {
      "type": "string",
      "default": "root",
      "description": "User to install dotfiles for"
    },
    "branch": {
      "type": "string",
      "default": "stow",
      "description": "Branch to checkout after cloning"
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils",
    "ghcr.io/devcontainers/features/git",
    "ghcr.io/devcontainers/features/github-cli",
    "ghcr.io/duduribeiro/devcontainer-features/tmux",
    "ghcr.io/rbharadwaj9/devcontainer-features/neovim:1"
  ]
}
